{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "server": {
      "type": "object",
      "properties": {
        "host": {
          "type": "string",
          "title": "Server Host",
          "description": "Hostname or IP address to bind to",
          "default": "127.0.0.1"
        },
        "port": {
          "type": "integer",
          "title": "Server Port",
          "description": "TCP port to listen on",
          "minimum": 1,
          "maximum": 65535,
          "default": 8080
        },
        "debug": {
          "type": "boolean",
          "description": "Enable debug mode"
        }
      },
      "required": ["host", "port"]
    },
    "database": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "description": "Database connection URL"
        },
        "pool_size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "timeout": {
          "type": "number",
          "minimum": 1,
          "maximum": 300
        }
      }
    },
    "logging": {
      "type": "object",
      "properties": {
        "level": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info"
        },
        "file": {
          "type": "string"
        },
        "format": {
          "type": "string",
          "enum": ["json", "text"]
        }
      }
    },
    "features": {
      "type": "object",
      "properties": {
        "names": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "enabled": {
          "type": "boolean"
        },
        "max_items": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
