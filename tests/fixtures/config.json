{
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "debug": true
  },
  "database": {
    "url": "postgresql://localhost:5432/mydb",
    "pool_size": 10,
    "timeout": 30.0
  },
  "logging": {
    "level": "info",
    "file": "/var/log/app.log",
    "format": "json"
  },
  "features": {
    "names": ["auth", "api", "webhooks"],
    "enabled": true,
    "max_items": 100
  }
}
